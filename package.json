{
  "name": "agent-starter",
  "version": "1.0.0",
  "private": true,
  "description": "Starter template for building AI chat agents on Cloudflare",
  "keywords": [
    "agents",
    "ai",
    "cloudflare"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.8.0",
  "scripts": {
    "dev": "vite dev",
    "start": "vite dev",
    "build": "vite build",
    "build-check": "vite build",
    "deploy": "vite build && wrangler deploy",
    "types": "wrangler types env.d.ts --include-runtime false",
    "check": "biome check .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "fix": "biome check --write .",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "ci": "pnpm run check && pnpm run check-types",
    "ci-quality": "pnpm run check && pnpm run check-types && pnpm run build-check",
    "verify": "pnpm run ci && pnpm run test"
  },
  "dependencies": {
    "@cloudflare/ai-chat": "^0.7.2",
    "@cloudflare/codemode": "^0.3.8",
    "@cloudflare/kumo": "^2.2.2",
    "@cloudflare/shell": "^0.3.8",
    "@cloudflare/think": "^0.7.3",
    "@phosphor-icons/react": "^2.1.10",
    "@streamdown/code": "^1.1.1",
    "agents": "^0.13.3",
    "ai": "^6.0.188",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "streamdown": "^2.5.0",
    "workers-ai-provider": "^3.1.14",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/plugin-proposal-decorators": "^7.29.0",
    "@biomejs/biome": "^2.3.0",
    "@cloudflare/vite-plugin": "1.37.2",
    "@cloudflare/workers-types": "^4.20260521.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14",
    "vitest": "^3.2.0",
    "wrangler": "^4.95.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js-pure",
      "esbuild",
      "sharp",
      "workerd"
    ]
  }
}
